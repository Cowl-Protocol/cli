# Copy to /etc/cowl-relayer/relayer.env, then: chown root:root && chmod 600.
#
# This is the passphrase for the DEDICATED relayer keystore in COWL_HOME, not
# the deployer's. The systemd unit reads it to unlock the wallet on boot, so the
# daemon can sign submissions without an interactive prompt.
COWL_PASSPHRASE=replace-with-the-relayer-keystore-passphrase
